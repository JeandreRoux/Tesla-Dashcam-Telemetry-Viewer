{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tesla Project",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "-i",
                "${workspaceFolder}/input",
                "-o",
                "${workspaceFolder}/output"
            ]
        },
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        }
    ]
}
